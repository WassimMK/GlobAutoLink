  <div class="year-range">
  <label>Min Year</label>
  <input type="number" name="minYear" placeholder="e.g. 2015" min="2015" max="2025" step="1">

  <label>Max Year</label>
  <input type="number" name="maxYear" placeholder="e.g. 2025" min="2015" max="2025" step="1">
</div>


  <select name="fuel">
    <option value="">Fuel Type</option>
    <option value="Electric">Electric</option>
    <option value="Diesel">Diesel</option>
    <option value="Petrol">Petrol</option>
    <option value="Hybrid">Hybrid</option>
  </select>

  <select name="gearbox">
    <option value="">Gearbox</option>
    <option value="Manual">Manual</option>
    <option value="Automatic">Automatic</option>
  </select>


  <div class="price-range">
    <label>Price Range</label>
    <input type="number" name="minPrice" placeholder="min" min="0" step="10">
    <input type="number" name="maxPrice" placeholder="max" min="0"  tep="10">
  </div>

  <div class="price-range">
    <label>Mileage max (km)</label>
    <input type="number" name="maxMileage" placeholder="e.g. 100000 km">
  </div>

  <button type="submit">Apply</button>
</form>

    <div class="cars-list">
  {{#each cars}}
  <a href="/cardetails/{{this.id}}" class="car-card-link">
    <div class="car-card">
      <img src="{{this.image}}" alt="{{this.title}}">
      <div class="info">
        <h3>{{this.title}}</h3>
        <p>{{this.year}} • {{this.gearbox}} • {{this.currentMiles}} km • {{this.energy}}</p>
        <strong>{{this.price}} €</strong>
        <div class="fav" data-id="{{this.id}}">
  <button class="fav-btn" data-fav="{{isFavorite}}">
    <i class="{{#if isFavorite}}fas{{else}}far{{/if}} fa-heart"></i>
  </button>
</div>

      </div>
    </div>
  </a>
{{/each}}
</div>
{{#unless cars.length}}
  <div class="no-results-container">
    <div class="no-results">
       No matching vehicles found.Please refine your search.
    </div>
  </div>
{{/unless}}

    <aside class="ads">ads</aside>
  </div>
</section>
