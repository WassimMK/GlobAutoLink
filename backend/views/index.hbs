          <option value="Yaris">Yaris</option>
        </select>
        <button type="submit">Search</button>
      </form>
    </div>
  </div>
</header>
<a href="/offers" class="subscribe-banner full-click">
  <span class="subscribe-btn">Subscribe now!</span>
</a>

<section class="home" id="home">
  <div class="home-text">
    <h1>WELCOME TO GLOBEAUTOLINK</h1>
    <p>Discover a wide range of vehicles, and enjoy seamless assistance with purchasing and importation.</p>
    <a href="#cars" class="btn">Discover Now</a>
  </div>
</section>

<section class="cars" id="cars">
  <div class="heading">
    <span>All Cars</span>
    <h2>We have all types of cars</h2>
    <p>Find your perfect vehicle from our wide selection of brands and models.</p>
  </div>
  <div class="car-list">
    <a href="/less3years">
      <div class="car-item">
        <img src="img/car1.png" alt="Car 1">
        <h3>-3 years old</h3>
        <p>Perfect for you</p>
      </div>
    </a>
    <a href="/recentlyadded">
      <div class="car-item">
        <img src="img/car2.png" alt="Car 2">
        <h3>Recently Added</h3>
        <p>The best in the market</p>
      </div>
    </a>
    <a href="/electric">
    <div class="car-item">
      <img src="img/car3.png" alt="Car 3">
      <h3>Electric</h3>
      <p>Try a new experience</p>
    </div>
    </a>
  </div>
</section>

<!-- BOUTON POUR MOBILE -->
<button class="toggle-filter-btn" onclick="toggleFilter()">☰ Filters</button>

<section class="filtre-container container">
  <h2><u>Explore vehicles</u></h2>

  <div class="filters-sortbar">
  <span id="clear-filters" class="clear-all">Clear all</span>
  
  <div class="sort-dropdown">
    <span id="sort-toggle" class="sort-by">Sort by: Newest <i class="fa fa-chevron-down"></i></span>
    <div id="sort-options" class="sort-options">
      <div data-sort="newest">Newest</div>
      <div data-sort="oldest">Oldest</div>
      <div data-sort="priceLow">Price: Low to High</div>
      <div data-sort="priceHigh">Price: High to Low</div>
    </div>
  </div>
</div>



  <div class="listing-wrapper">
    <button type="button" class="toggle-filters">Show Filters</button>
    <form method="GET" action="/" class="filters">
     <select name="carType">
  <option value="">Car Type</option>
  <option value="SUV">SUV</option>
  <option value="Sedan">Sedan</option>
  <option value="Hatchback">Hatchback</option>
  <option value="Pickup">Pickup</option>
  <option value="Coupe">Coupe</option>

  
</select>


   <select name="carBrand" id="brand">
  <option value="">Brand</option>
  <option value="Audi">Audi</option>
  <option value="BMW">BMW</option>
  <option value="Chery">Chery</option>
  <option value="Chevrolet">Chevrolet</option>
