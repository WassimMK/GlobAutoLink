    <div class="filter-section">
      <h2>Quick Search</h2>
      <form action="/" method="GET" class="quick-search-form">
        <input type="number" name="minYear" placeholder="Min Year" min="2015" max="2025" step="1">
        <input type="number" name="maxYear" placeholder="Max Year" min="2015" max="2025" step="1">
        <select name="carBrand">
